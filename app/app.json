{
  "expo": {
    "name": "Next Step",
    "slug": "next-step",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "nextstep",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#066CF4"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nextstep.app",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Next Step utilizza la tua posizione per mostrarti le scuole vicine sulla mappa."
      }
    },
    "android": {
      "package": "com.nextstep.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#066CF4"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Next Step utilizza la tua posizione per mostrarti le scuole vicine."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
